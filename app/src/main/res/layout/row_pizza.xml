<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="118dp"
    android:background="#2E7D32"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imagePizzaItem"
        android:layout_width="94dp"
        android:layout_height="94dp"
        android:layout_alignParentStart="true"
        android:background="#FFFFFF"
        android:contentDescription="image pizza"
        android:padding="2dp"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/nomPizzaItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_toEndOf="@id/imagePizzaItem"
        android:textColor="#FFF59D"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/infosPizzaItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/nomPizzaItem"
        android:layout_marginStart="14dp"
        android:layout_marginTop="10dp"
        android:layout_toEndOf="@id/imagePizzaItem"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/prixPizzaItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="14dp"
        android:layout_toEndOf="@id/imagePizzaItem"
        android:textColor="#FFEB3B"
        android:textSize="16sp"
        android:textStyle="bold" />
</RelativeLayout>